  },
  "source": {
    "default_extensions": [
      ".cpp",
      ".h",
      ".py",
      ".js",
      ".md"
    ],
    "encoding": "utf-8",
    "global_exclude": [
      "*/node_modules/*",
      "*.min.js",
      "*.log",
      "*/.git/*",
      ".gitignore",
      "*/CVS/*",
      "*/debug/*",
      "*/release/*",
      "*/lib/*",
      "*/docker/*",
      "*/fonts/*",
      "*/images/*",
      "*/test/*",
      "*/tests/*",
      "*/example/*",
      "*/examples/*",
      "*/obj/*",
      "*/build_dbg/*",
      "*/build_rel/*"
    ],
    "max_file_size_mb": 10,
    "paths": [
      {
        "exclude": [
          "*/build/*",
          "*/build_rel/*",
          "*/dist/*",
          "*/test/*",
          "*/3rdparty/*"
        ],
        "extensions": [
          ".cpp",
          ".h",
          ".hpp"
        ],
        "path": "../../phenixcode/",
        "recursive": true,
        "type": "directory"
      },
      {
        "path": "../../settings.json_",
        "type": "file"
      },
      {
        "headers": {
          "Authorization": "Bearer ${GITHUB_TOKEN}"
        },
        "type": "url",
        "url": "https://raw.githubusercontent.com/user/repo/main/docs/api.md"
      },
      {
        "timeout_ms": 10000,
        "type": "url",
        "url": "https://docs.example.com/api"
      }
    ],
    "project_id": "phenixcode-97ecf67f",
    "project_title": "phenixcode"
  },
